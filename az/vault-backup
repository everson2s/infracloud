## 11. Script completo de backup

Crie um arquivo chamado:

```bash
backup-keyvault.sh
```

Conteúdo:

```bash
#!/bin/bash

set -euo pipefail

SUBSCRIPTION_ID="<subscription-id>"
SOURCE_VAULT="<key-vault-origem>"
BACKUP_DIR="./keyvault-backup"

echo "Selecionando subscription..."
az account set --subscription "$SUBSCRIPTION_ID"

echo "Criando estrutura de diretórios..."
mkdir -p "$BACKUP_DIR/secrets"
mkdir -p "$BACKUP_DIR/keys"
mkdir -p "$BACKUP_DIR/certificates"

echo "Iniciando backup de secrets..."
for secret in $(az keyvault secret list \
  --vault-name "$SOURCE_VAULT" \
  --query "[].name" -o tsv); do

  echo "Backup secret: $secret"

  az keyvault secret backup \
    --vault-name "$SOURCE_VAULT" \
    --name "$secret" \
    --file "$BACKUP_DIR/secrets/$secret.bak"
done

echo "Iniciando backup de keys..."
for key in $(az keyvault key list \
  --vault-name "$SOURCE_VAULT" \
  --query "[].name" -o tsv); do

  echo "Backup key: $key"

  az keyvault key backup \
    --vault-name "$SOURCE_VAULT" \
    --name "$key" \
    --file "$BACKUP_DIR/keys/$key.bak"
done

echo "Iniciando backup de certificates..."
for cert in $(az keyvault certificate list \
  --vault-name "$SOURCE_VAULT" \
  --query "[].name" -o tsv); do

  echo "Backup certificate: $cert"

  az keyvault certificate backup \
    --vault-name "$SOURCE_VAULT" \
    --name "$cert" \
    --file "$BACKUP_DIR/certificates/$cert.bak"
done

echo "Backup finalizado com sucesso."
echo "Arquivos salvos em: $BACKUP_DIR"
```

Dar permissão de execução:

```bash
chmod +x backup-keyvault.sh
```

Executar:

```bash
./backup-keyvault.sh
```

